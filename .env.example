# Slack Off mobile environment examples.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.

# local | staging | production
EXPO_PUBLIC_APP_ENV=local

# Local simulator can use localhost when the API runs on the same machine.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Local/staging access token. Generate a local token from the API repo with:
# SUPABASE_JWT_SECRET=dev-secret-change-me npm run auth:dev-token
EXPO_PUBLIC_ACCESS_TOKEN=

# Staging example:
# EXPO_PUBLIC_APP_ENV=staging
# EXPO_PUBLIC_API_BASE_URL=https://staging-api.example.com
# EXPO_PUBLIC_ACCESS_TOKEN=

# Production example:
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com
# EXPO_PUBLIC_ACCESS_TOKEN=
